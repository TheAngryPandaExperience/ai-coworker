{
  "name": "ai-coworker",
  "version": "1.0.0",
  "description": "Autonomous AI coworker development environment scaffold",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "hathr": "node src/hathr/cli.js",
    "hathr:setup": "node -e \"import('./src/hathr/runner.js').then(m=>m.openSetupBrowser((e,d)=>console.log(d?.message??e))).catch(console.error)\"",
    "test": "node --test tests/**/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
